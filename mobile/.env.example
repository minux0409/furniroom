# Google OAuth Web Client ID (Google Cloud Console에서 발급)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# EAS Project ID (eas init 실행 후 자동 발급)
EAS_PROJECT_ID=
